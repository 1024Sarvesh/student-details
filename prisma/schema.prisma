generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model studentReg {
  id         Int       @id @default(autoincrement())
  name       String    @unique
  fatherName String
  mobileNo   String    @unique
  address    String
  photoUrl    String?
  created_at DateTime?
}
